{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "jsx": "preserve",
        "plugins": [{ "name": "next" }],
        "paths": {
            "@lector/core/*": ["../../packages/core/src/*"],
            "@lector/presets/*": ["../../packages/presets/src/*"],
            "@/*": ["./*"]
        }
    },
    "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
    "exclude": ["node_modules"]
}
